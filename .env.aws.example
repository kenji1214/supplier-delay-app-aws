ENV=aws
PORT=8000
USE_MOCK_DATA=false
CURRENT_USER=apprunner
SQLITE_PATH=/app/data/comments.db
CORS_ORIGINS=

# Snowflake runtime configuration
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=

# AWS deployment metadata
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ECR_REPOSITORY=supplier-delay-app
AWS_APPRUNNER_SERVICE_NAME=supplier-delay-app
